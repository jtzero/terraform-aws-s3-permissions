#!/usr/bin/env bash

set -euo pipefail

SCRIPTS_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
PROJECT_DIR="$(dirname "$SCRIPTS_DIR")"
TEST_DIR="${PROJECT_DIR}/tests"

cd "${TEST_DIR}/stack" || exit 1

# Start the moto stack in the background if it isn't already accepting connections.
if ! curl --fail --silent http://localhost:5000/moto-api/ >/dev/null 2>&1; then
  moto_server -p 5000 >/tmp/moto_server.log 2>&1 &
  for _ in $(seq 1 30); do
    curl --fail --silent http://localhost:5000/moto-api/ >/dev/null 2>&1 && break
    sleep 1
  done
fi

printf "%s\n" "${PWD}"

terraform init
terraform apply -auto-approve
